@inherits LayoutComponentBase

<div class="flex flex-col h-screen bg-zinc-950">
    <main class="flex-1 app-scrollable">
        <ErrorBoundary>
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="p-6 text-red-400">
                    <p class="font-semibold">Something went wrong</p>
                    <p class="text-sm text-zinc-400 mt-1">@ex.Message</p>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </main>
</div>

@code { }

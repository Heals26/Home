@* Top navigation bar with optional back button, title, subtitle and actions slot. *@

<header class="flex items-center justify-between px-4 py-3 bg-zinc-950 border-b border-zinc-800 shrink-0 min-h-[64px]">
    <div class="flex items-center gap-3 min-w-0">
        @if (this.ShowBack)
        {
            <button class="p-2 -ml-2 text-zinc-400 hover:text-zinc-50 rounded-lg transition-colors shrink-0"
                    @onclick="this.GoBack">
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </button>
        }
        <div class="min-w-0">
            <h1 class="text-base font-semibold text-zinc-50 truncate">@this.Title</h1>
            @if (!string.IsNullOrEmpty(this.Subtitle))
            {
                <p class="text-xs text-zinc-500 truncate">@this.Subtitle</p>
            }
        </div>
    </div>
    @if (this.ActionsContent != null)
    {
        <div class="flex items-center gap-2 shrink-0 ml-3">
            @this.ActionsContent
        </div>
    }
</header>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public bool ShowBack { get; set; } = true;
    [Parameter] public string BackHref { get; set; } = "/";
    [Parameter] public RenderFragment? ActionsContent { get; set; }

    private void GoBack()
        => this.NavigationManager.NavigateTo(this.BackHref);
}

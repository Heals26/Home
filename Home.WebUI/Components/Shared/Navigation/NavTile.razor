@* Large navigation tile for the home dashboard - Crown Sydney style *@

<a href="@Href"
   class="relative group flex flex-col items-center justify-center gap-3 bg-zinc-900 hover:bg-zinc-800 active:bg-zinc-800 active:scale-95 border border-zinc-800 hover:border-zinc-700 rounded-2xl p-6 transition-all duration-150 min-h-[140px] cursor-pointer select-none @Class">
    <div class="text-teal-400 group-hover:text-teal-300 transition-colors">
        @IconContent
    </div>
    <div class="text-center">
        <p class="text-sm font-semibold text-zinc-50 group-hover:text-white">@Label</p>
        @if (!string.IsNullOrEmpty(Subtitle))
        {
            <p class="text-xs text-zinc-500 mt-0.5">@Subtitle</p>
        }
    </div>
    @if (Badge > 0)
    {
        <span class="absolute top-3 right-3 bg-teal-500 text-white text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center">
            @Badge
        </span>
    }
</a>

@code {
    [Parameter] public string Href { get; set; } = "#";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public RenderFragment? IconContent { get; set; }
    [Parameter] public int Badge { get; set; }
    [Parameter] public string? Class { get; set; }
}

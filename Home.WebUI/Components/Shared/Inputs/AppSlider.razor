@* Range slider for continuous values (brightness, temperature, volume) *@

<div class="flex flex-col gap-2 @Class">
    @if (!string.IsNullOrEmpty(Label))
    {
        <div class="flex justify-between items-center">
            <label class="text-sm font-medium text-zinc-300">@Label</label>
            <span class="text-sm font-semibold text-teal-400">@Value@Unit</span>
        </div>
    }
    <input type="range"
           min="@Min"
           max="@Max"
           step="@Step"
           value="@Value"
           disabled="@Disabled"
           @oninput="OnInputChanged"
           class="w-full h-2 bg-zinc-700 rounded-full appearance-none cursor-pointer accent-teal-500 disabled:opacity-50" />
</div>

@code {
    [Parameter] public double Value { get; set; }
    [Parameter] public EventCallback<double> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string Unit { get; set; } = "";
    [Parameter] public double Min { get; set; } = 0;
    [Parameter] public double Max { get; set; } = 100;
    [Parameter] public double Step { get; set; } = 1;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }

    private async Task OnInputChanged(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var _Val))
            await ValueChanged.InvokeAsync(_Val);
    }
}

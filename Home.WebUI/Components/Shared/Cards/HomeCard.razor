@* Surface card with optional title, subtitle and actions slot. *@

<div class="@this.GetClasses()">
    @if (this.Title != null || this.TitleContent != null || this.ActionsContent != null)
    {
        <div class="flex items-center justify-between px-5 py-4 border-b border-zinc-800">
            <div>
                @if (this.TitleContent != null)
                {
                    @this.TitleContent
                }
                else if (this.Title != null)
                {
                    <h2 class="text-base font-semibold text-zinc-50">@this.Title</h2>
                }
                @if (this.Subtitle != null)
                {
                    <p class="text-sm text-zinc-400 mt-0.5">@this.Subtitle</p>
                }
            </div>
            @if (this.ActionsContent != null)
            {
                <div class="flex items-center gap-2">
                    @this.ActionsContent
                </div>
            }
        </div>
    }
    <div class="@(this.Padded ? "p-5" : "")">
        @this.ChildContent
    </div>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? TitleContent { get; set; }
    [Parameter] public RenderFragment? ActionsContent { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public bool Padded { get; set; } = true;
    [Parameter] public string? Class { get; set; }

    private string GetClasses()
        => $"bg-zinc-900 rounded-xl border border-zinc-800 overflow-hidden {this.Class}";
}

@page "/"
@page "/home"

<div class="flex flex-col h-full bg-zinc-950">
    @* Header *@
    <header class="flex items-center justify-between px-6 py-5 shrink-0">
        <div>
            <p class="text-xs font-medium text-zinc-500 uppercase tracking-widest">Home</p>
            <h1 class="text-2xl font-bold text-zinc-50 mt-0.5">Good @this.GetGreeting()</h1>
        </div>
        <div class="text-right">
            <p class="text-sm text-zinc-400">@DateTime.Now.ToString("dddd")</p>
            <p class="text-xs text-zinc-600">@DateTime.Now.ToString("d MMMM")</p>
        </div>
    </header>

    @* Tiles grid *@
    <div class="flex-1 px-4 pb-6 app-scrollable">
        <div class="grid grid-cols-2 gap-4 max-w-2xl mx-auto">

            <HomeNavTile Href="/shopping-lists" Label="Shopping Lists" Subtitle="Manage your lists">
                <IconContent>
                    <span class="home-icon home-icon-shopping-list h-10 w-10 inline-block"></span>
                </IconContent>
            </HomeNavTile>

            <HomeNavTile Href="/recipes" Label="Recipes" Subtitle="Browse &amp; cook">
                <IconContent>
                    <span class="home-icon home-icon-book h-10 w-10 inline-block"></span>
                </IconContent>
            </HomeNavTile>

            <HomeNavTile Href="/lights" Label="Lights" Subtitle="Coming soon" Class="opacity-50 pointer-events-none">
                <IconContent>
                    <span class="home-icon home-icon-lightbulb h-10 w-10 inline-block"></span>
                </IconContent>
            </HomeNavTile>

            <HomeNavTile Href="/settings" Label="Settings" Subtitle="Coming soon" Class="opacity-50 pointer-events-none">
                <IconContent>
                    <span class="home-icon home-icon-cog h-10 w-10 inline-block"></span>
                </IconContent>
            </HomeNavTile>

        </div>
    </div>
</div>

@code {

    #region Methods

    private string GetGreeting()
    {
        var _Hour = DateTime.Now.Hour;
        return _Hour switch
        {
            < 12 => "morning",
            < 17 => "afternoon",
            _    => "evening"
        };
    }

    #endregion Methods

}

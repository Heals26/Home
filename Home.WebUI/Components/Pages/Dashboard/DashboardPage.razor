@page "/"
@page "/home"

<div class="flex flex-col h-full bg-zinc-950">
    @* Header *@
    <header class="flex items-center justify-between px-6 py-5 shrink-0">
        <div>
            <p class="text-xs font-medium text-zinc-500 uppercase tracking-widest">Home</p>
            <h1 class="text-2xl font-bold text-zinc-50 mt-0.5">Good @this.GetGreeting()</h1>
        </div>
        <div class="text-right">
            <p class="text-sm text-zinc-400">@DateTime.Now.ToString("dddd")</p>
            <p class="text-xs text-zinc-600">@DateTime.Now.ToString("d MMMM")</p>
        </div>
    </header>

    @* Tiles grid *@
    <div class="flex-1 px-4 pb-6 app-scrollable">
        <div class="grid grid-cols-2 gap-4 max-w-2xl mx-auto">

            <HomeNavTile Href="/shopping-carts" Label="Shopping Lists" Subtitle="Manage your lists">
                <IconContent>
                    <svg class="h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                    </svg>
                </IconContent>
            </HomeNavTile>

            <HomeNavTile Href="/recipes" Label="Recipes" Subtitle="Browse &amp; cook">
                <IconContent>
                    <svg class="h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                </IconContent>
            </HomeNavTile>

            <HomeNavTile Href="/lights" Label="Lights" Subtitle="Coming soon" Class="opacity-50 pointer-events-none">
                <IconContent>
                    <svg class="h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                    </svg>
                </IconContent>
            </HomeNavTile>

            <HomeNavTile Href="/settings" Label="Settings" Subtitle="Coming soon" Class="opacity-50 pointer-events-none">
                <IconContent>
                    <svg class="h-10 w-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                </IconContent>
            </HomeNavTile>

        </div>
    </div>
</div>

@code {

    #region Methods

    private string GetGreeting()
    {
        var _Hour = DateTime.Now.Hour;
        return _Hour switch
        {
            < 12 => "morning",
            < 17 => "afternoon",
            _    => "evening"
        };
    }

    #endregion Methods

}

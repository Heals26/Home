@page "/shopping-lists"
@page "/shopping-lists/{ShoppingListID:long}"

<CascadingValue Value="this.m_CancellationTokenHandler.Token" Name="CancellationToken">
    <div class="flex flex-col h-full">
        <HomeTopBar Title="Shopping Lists" ShowBack="true" BackHref="/" />
        <div class="flex-1 flex flex-col lg:flex-row gap-4 p-4 app-scrollable">
            <div class="lg:w-1/3 shrink-0">
                <ShoppingListsComponent ShoppingListID="this.ShoppingListID" />
            </div>
            <div class="flex-1 min-w-0">
                <ShoppingListComponent ShoppingListID="this.ShoppingListID" />
            </div>
        </div>
    </div>
</CascadingValue>

@code {

    #region Fields

    private CancellationTokenHandler m_CancellationTokenHandler = new();

    #endregion Fields

    #region Properties

    [Parameter] public long? ShoppingListID { get; set; }

    #endregion Properties

}

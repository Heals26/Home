@using Home.WebUI.DataAccess.ShoppingCarts.GetShoppingCart
@using Home.WebUI.DataAccess.ShoppingCarts.GetShoppingCarts
@using Home.WebUI.DataAccess.ShoppingCarts.CreateShoppingCart

<HomeCard Title="Lists">
    <ActionsContent>
        <HomeButton Size="sm" OnClick="this.OpenCreateModal">
            <span class="home-icon home-icon-plus h-4 w-4 mr-1 inline-block"></span>
            New
        </HomeButton>
    </ActionsContent>
    <ChildContent>
        @if (this.m_ShoppingCarts == null)
        {
            <HomeLoader Class="py-8" />
        }
        else if (!this.m_ShoppingCarts.ShoppingCarts.Any())
        {
            <HomeEmptyState Title="No lists yet" Subtitle="Create your first shopping list">
                <ActionContent>
                    <HomeButton OnClick="this.OpenCreateModal">Create List</HomeButton>
                </ActionContent>
            </HomeEmptyState>
        }
        else
        {
            <div class="divide-y divide-zinc-800 -mx-5 -mb-5">
                @foreach (var _Cart in this.m_ShoppingCarts.ShoppingCarts)
                {
                    <button class="w-full text-left px-5 py-4 hover:bg-zinc-800 active:bg-zinc-800 transition-colors"
                            @onclick="() => this.SelectCart(_Cart)">
                        <p class="text-sm font-medium text-zinc-50">@_Cart.Name</p>
                        <p class="text-xs text-zinc-500 mt-0.5">@_Cart.ItemCount items</p>
                    </button>
                }
            </div>
        }
    </ChildContent>
</HomeCard>

<HomeModal @bind-Visible="this.m_ShowCreate" Title="New Shopping List">
    <ChildContent>
        <EditForm Model="this.m_CreateRequest" OnValidSubmit="this.CreateShoppingCartAsync">
            <HomeTextInput Label="List name"
                           @bind-Value="this.m_CreateRequest!.Name"
                           Placeholder="e.g. Weekly shop" />
            <div class="mt-4 flex justify-end gap-3">
                <HomeButton Variant="ghost" OnClick="() => this.m_ShowCreate = false">Cancel</HomeButton>
                <HomeButton Type="submit" Loading="this.m_Creating">Create</HomeButton>
            </div>
        </EditForm>
    </ChildContent>
</HomeModal>

<ErrorHandler @ref="this.m_ErrorHandler" />

@code {

    #region Fields

    private ErrorHandler? m_ErrorHandler;
    private CreateShoppingCartWebAppRequest? m_CreateRequest = new();
    private GetShoppingCartsWebAppResponse? m_ShoppingCarts;
    private bool m_ShowCreate;
    private bool m_Creating;

    #endregion Fields

    #region Properties

    [CascadingParameter(Name = "CancellationToken")] public CancellationToken CancellationToken { get; set; }
    [Parameter] public long? ShoppingCartID { get; set; }
    [Parameter] public EventCallback<long> ShoppingCartIDChanged { get; set; }

    #endregion Properties

    #region Lifecycle Methods

    protected override async Task OnInitializedAsync()
    {
        var _Result = await this.ApiAccess.SendRequestAsync<object, GetShoppingCartsWebAppResponse>(
            null!, ApiProvider.GetShoppingCarts(),
            e => this.m_ErrorHandler?.AddError(e),
            this.CancellationToken);

        if (_Result != null)
            this.m_ShoppingCarts = _Result;
    }

    #endregion Lifecycle Methods

    #region Methods

    private void OpenCreateModal()
        => this.m_ShowCreate = true;

    private void SelectCart(GetShoppingCartDto cart)
        => this.NavigationManager.NavigateTo($"/shopping-carts/{cart.ShoppingCartID}");

    private async Task CreateShoppingCartAsync()
    {
        this.m_Creating = true;

        await this.ApiAccess.SendRequestAsync<CreateShoppingCartWebAppRequest, CreateShoppingCartWebAppResponse>(
            this.m_CreateRequest!,
            ApiProvider.CreateShoppingCart(),
            e => this.m_ErrorHandler!.AddError(e),
            this.CancellationToken);

        this.m_Creating = false;
        this.m_ShowCreate = false;
        this.m_CreateRequest = new();

        await this.OnInitializedAsync();
    }

    #endregion Methods

}

@using Microsoft.AspNetCore.Mvc

@if (this.m_Errors.Any())
{
    <div class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 max-w-sm">
        @foreach (var _Error in this.m_Errors)
        {
            <div class="bg-red-900/90 border border-red-700 text-red-100 rounded-xl px-4 py-3 text-sm shadow-lg">
                @_Error
            </div>
        }
    </div>
}

@code {
    #region Fields
    private List<string> m_Errors = new();
    #endregion Fields

    #region Methods
    public void AddError(ValidationProblemDetails errors)
    {
        if (errors.Errors != null)
            foreach (var _Error in errors.Errors)
                this.m_Errors.AddRange(_Error.Value);
        StateHasChanged();
    }

    public void AddError(string error)
    {
        this.m_Errors.Add(error);
        StateHasChanged();
    }

    public void ResetErrors()
    {
        this.m_Errors.Clear();
        StateHasChanged();
    }
    #endregion Methods
}
